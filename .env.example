# Billing Simulation (Development/Testing Only)
# Set to 'true' ONLY for local development to test Premium features without real billing
# MUST be 'false' or omitted in production
NEXT_PUBLIC_ENABLE_BILLING_SIMULATION=false

# ABN Lookup (ABR web-services GUID)
# Register at https://abr.business.gov.au/Tools/WebServiceRegistration
ABR_GUID=

# Stripe (billing)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Primary premium subscription price (required for checkout/webhook checks)
STRIPE_PREMIUM_PRICE_ID=
# App URL for Stripe redirects (success/cancel/portal return)
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Optional: enable webhook debug logging
# DEBUG_STRIPE_WEBHOOK=true

# Legacy/alternative price IDs (optional)
STRIPE_PRICE_PREMIUM=
STRIPE_PRICE_BUSINESS_PRO_20=
STRIPE_PRICE_SUBCONTRACTOR_PRO_10=
STRIPE_PRICE_ALL_ACCESS_PRO_26=

# Playwright E2E (optional; defaults shown)
PW_BASE_URL=http://localhost:3000
# QA seed users (run npm run qa:seed first)
PW_EMAIL=pw-free@tradehub.test
PW_PASSWORD=password1
# Premium user: pw-premium@tradehub.test (from qa:seed) or test5@gmail.com (manual)
PW_PREMIUM_EMAIL=pw-premium@tradehub.test
PW_PREMIUM_PASSWORD=password1

# Unverified user for ABN gating tests (requires pw:seed:qa)
PW_NO_ABN_EMAIL=pw-unverified@tradehub.test
PW_NO_ABN_PASSWORD=password1

# Plastering user for tender-discovery-visibility tests (from qa:seed)
PW_PLASTERING_EMAIL=pw-plastering@tradehub.test
PW_PLASTERING_PASSWORD=password1

# Required for qa:seed (creates deterministic QA records)
SUPABASE_SERVICE_ROLE_KEY=

# Resend (email alerts for new jobs/tenders)
RESEND_API_KEY=
ALERTS_FROM_EMAIL=
ALERTS_FROM_NAME=TradeHub

# Transactional email pipeline
EMAIL_FROM=hello@tradehub.com.au
# Internal auth for server -> edge email function invocation
EMAIL_PIPELINE_SECRET=
# Canonical app URL used in transactional email links
APP_BASE_URL=https://tradehub.com.au

# Cron (for /api/cron/cleanup-expired-tenders - full DB + storage cleanup via Vercel cron)
# Vercel sends this as Authorization: Bearer <secret> when invoking cron jobs
CRON_SECRET=
