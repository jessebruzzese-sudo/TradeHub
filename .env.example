# Copy to .env.local and fill in values. Do not commit real secrets.

# --- Vercel / production (required for app + build checks) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

GOOGLE_PLACES_API_KEY=

STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

OPENAI_API_KEY=

NEXT_PUBLIC_SITE_URL=
NEXT_PUBLIC_APP_URL=

BILLING_ENABLED=true
NEXT_PUBLIC_BILLING_ENABLED=true

# --- Billing simulation (local only; false in production) ---
NEXT_PUBLIC_ENABLE_BILLING_SIMULATION=false

# ABN Lookup (ABR web-services GUID)
# https://abr.business.gov.au/Tools/WebServiceRegistration
ABR_GUID=

# Stripe price IDs
STRIPE_PREMIUM_PRICE_ID=
STRIPE_PRICE_PREMIUM=
STRIPE_PRICE_BUSINESS_PRO_20=
STRIPE_PRICE_SUBCONTRACTOR_PRO_10=
STRIPE_PRICE_ALL_ACCESS_PRO_26=

# Playwright E2E (optional)
PW_BASE_URL=http://localhost:3000
PW_EMAIL=pw-free@tradehub.test
PW_PASSWORD=password1
PW_PREMIUM_EMAIL=pw-premium@tradehub.test
PW_PREMIUM_PASSWORD=password1
PW_NO_ABN_EMAIL=pw-unverified@tradehub.test
PW_NO_ABN_PASSWORD=password1
PW_PLASTERING_EMAIL=pw-plastering@tradehub.test
PW_PLASTERING_PASSWORD=password1

# Resend / email
RESEND_API_KEY=
ALERTS_FROM_EMAIL=
ALERTS_FROM_NAME=TradeHub
EMAIL_FROM=hello@tradehub.com.au
EMAIL_PIPELINE_SECRET=
